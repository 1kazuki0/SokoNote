<% content_for :title do %>
  登録完了
<% end %>

<div class="flex flex-1 flex-col items-center">
  <div class="w-full max-w-3xl">

    <!-- 成功アイコン（二重リング演出） -->
    <div class="flex justify-center mb-3 relative h-20 items-center">
      <div class="absolute w-20 h-20 rounded-full bg-primary/10"></div>
      <div class="absolute w-16 h-16 rounded-full bg-primary/20"></div>
      <div class="relative z-10 w-12 h-12 rounded-full bg-primary flex items-center justify-center">
        <span class="material-symbols-outlined text-white" style="font-size: 24px; font-weight: 700;">check</span>
      </div>
    </div>

    <!-- 見出し -->
    <h2 class="text-center text-xl font-bold text-black mt-2 mb-0.5">登録しました</h2>
    <p class="text-center text-xs text-middle-gray mb-5">お疲れさまでした</p>

    <!-- 登録内容サマリーカード（単価をヒーロー表示） -->
    <div class="bg-white rounded-2xl border border-light-gray px-4 py-4 mb-5 shadow-md shadow-black/5">
      <p class="text-xl font-bold text-black text-center mb-3"><%= @item.name %></p>

      <!-- 単価 -->
      <div class="bg-primary/5 rounded-2xl py-3 px-3 text-center mb-3">
        <p class="text-xs text-middle-gray mb-1 tracking-wide">
          1<%= @purchase.content_unit.name %>あたりの単価
        </p>
        <div class="flex items-baseline justify-center gap-0.5">
          <span class="text-3xl font-bold text-primary leading-none">
            <%= format("%.2f", @purchase.unit_price) %>
          </span>
          <span class="text-sm text-black font-medium">円</span>
        </div>
      </div>

      <!-- 内容量・価格 -->
      <div class="flex justify-between text-xs px-1">
        <div>
          <p class="text-middle-gray m-0">内容量</p>
          <p class="text-black font-medium mt-0.5">
            <%= @purchase.content_quantity %><%= @purchase.content_unit.name %>
          </p>
        </div>
        <div class="text-right">
          <p class="text-middle-gray m-0">価格（税率<%= @purchase.tax_rate %>%）</p>
          <p class="text-black font-medium mt-0.5">¥<%= @purchase.price %></p>
        </div>
      </div>
    </div>

    <!-- 問いかけ -->
    <p class="text-center text-xs text-middle-gray mb-3">次にどうしますか？</p>

    <!-- 3つの選択肢（アクセントカラー＋補助文＋矢印） -->
    <div class="flex flex-col gap-2">

      <!-- 詳細情報を追加する -->
      <%= link_to edit_item_purchase_path(@item, @purchase), class: "card bg-white border border-light-gray rounded-2xl px-4 py-3.5 flex items-center gap-3", data: { controller: "button", action: "touchstart->button#press touchend->button#release touchcancel->button#release" } do %>
        <div class="w-9 h-9 rounded-xl bg-dark-gray/10 flex items-center justify-center flex-shrink-0">
          <span class="material-symbols-outlined text-dark-gray" style="font-size: 18px;">edit</span>
        </div>
        <div class="flex-1 min-w-0">
          <p class="font-medium text-black m-0">詳細情報を追加する</p>
          <p class="text-sm text-middle-gray mt-0.5">店舗・カテゴリーなど（任意）</p>
        </div>
        <span class="material-symbols-outlined text-middle-gray">chevron_right</span>
      <% end %>

      <!-- 一覧画面に戻る -->
      <%= link_to items_path, class: "card bg-white border border-light-gray rounded-2xl px-4 py-3.5 flex items-center gap-3", data: { controller: "button", action: "touchstart->button#press touchend->button#release touchcancel->button#release" } do %>
        <div class="w-9 h-9 rounded-xl bg-accent/10 flex items-center justify-center flex-shrink-0">
          <span class="material-symbols-outlined text-accent" style="font-size: 18px;">list_alt</span>
        </div>
        <div class="flex-1 min-w-0">
          <p class="font-medium text-black m-0">一覧画面に戻る</p>
          <p class="text-sm text-middle-gray mt-0.5">登録済みの商品を確認</p>
        </div>
        <span class="material-symbols-outlined text-middle-gray">chevron_right</span>
      <% end %>

      <!-- もう1件登録する -->
      <%= link_to new_item_registration_path, class: "card bg-white border border-light-gray rounded-2xl px-4 py-3.5 flex items-center gap-3", data: { controller: "button", action: "touchstart->button#press touchend->button#release touchcancel->button#release" } do %>
        <div class="w-9 h-9 rounded-xl bg-primary/10 flex items-center justify-center flex-shrink-0">
          <span class="material-symbols-outlined text-primary" style="font-size: 18px;">add</span>
        </div>
        <div class="flex-1 min-w-0">
          <p class="font-medium text-black m-0">もう1件登録する</p>
          <p class="text-sm text-middle-gray mt-0.5">同じフォームで続けて入力</p>
        </div>
        <span class="material-symbols-outlined text-middle-gray">chevron_right</span>
      <% end %>
    </div>
  </div>
</div>
