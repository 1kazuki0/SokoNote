<!-- 商品一覧画面 -->
<!-- タイトル表示 -->
<% content_for :title do %>
  商品一覧
<% end %>

<!-- 1件以上の商品が登録されている場合 -->
<% if @has_any_items %>
  <!-- 検索フォーム -->
  <div class="mb-4">
    <%= search_form_for @q do |f| %>
      <div class="form flex">
        <span class="material-symbols-outlined text-middle-gray">search</span>
        <%= f.search_field :name_cont, placeholder: "商品を検索", class: "flex-auto outline-none pl-2 text-black bg-transparent placeholder-gray" %>
      </div>
    <% end %>
  </div>
  <!-- カテゴリの選択絞り込み -->
  <div class="mb-4 flex gap-2 overflow-auto pb-1" style="scrollbar-width: thin;">
    <%= link_to "全て", items_path, class: "flex-shrink-0 px-4 py-1.5 rounded-full text-sm font-bold whitespace-nowrap #{params.dig(:q, :category_id_eq).blank? && params.dig(:q, :category_id_null) != "1" ? 'bg-primary text-white' : 'bg-white text-middle-gray border border-light-gray'}" %>

    <!-- カテゴリごとのチップ -->
    <% @categories.each do |category| %>
      <%= link_to category.name,
          items_path(q: { category_id_eq: category.id }),
          class: "flex-shrink-0 px-4 py-1.5 rounded-full text-sm font-bold whitespace-nowrap #{params.dig(:q, :category_id_eq).to_s == category.id.to_s ? 'bg-primary text-white' : 'bg-white text-middle-gray border border-light-gray'}" %>
    <% end %>

    <!-- 「未登録」チップ -->
    <%= link_to "未登録",
        items_path(q: { category_id_null: "1" }),
        class: "flex-shrink-0 px-4 py-1.5 rounded-full text-sm font-bold whitespace-nowrap #{params.dig(:q, :category_id_null) == "1" ? 'bg-primary text-white' : 'bg-white text-middle-gray border border-light-gray'}" %>
  </div>
    
  <!-- 検索した結果、商品がない場合 -->
  <% if @items.empty? %>
    <div class="flex flex-col items-center text-center py-12">
      <span class="material-symbols-outlined mb-5 text-middle-gray" style="font-size: 80px;">search_off</span>
      <h2 class="text-lg font-bold text-gray-600 mb-2">
        検索した結果、見つかりませんでした
      </h2>
      <p class="text-sm text-gray-400 mb-6">
        この商品はまだ登録されていない可能性があります
      </p>

      <!-- 商品登録遷移ボタン -->
      <div class="w-full p-6">
        <%= link_to new_item_registration_path, class: "card bg-primary text-white px-6 py-4 rounded-full flex items-center justify-center font-bold", data: { controller: "button", action: "touchstart->button#press touchend->button#release touchcancel->button#release" } do %>
          <span class="text-lg">商品を登録する</span>
          <span class="material-symbols-outlined">add</span>
        <% end %>
      </div>

      <%= link_to "検索条件をリセット", items_path, class: "text-lg link text-primary font-bold" %>
    </div>

  <!-- 検索した結果、商品がある場合 -->
  <% else %>
    <div class="space-y-3">
      <% @items.each do |item| %>
        <% cheapest = item.purchases.min_by { |p| p.unit_price } %>
        <%= link_to item_purchases_path(item), class: "card bg-white rounded-2xl overflow-hidden border border-light-gray flex" do %>

          <!-- 左ボーダー：購入履歴があれば緑、なければグレー -->
          <div class="w-1.5 flex-shrink-0 <%= cheapest ? 'bg-primary' : 'bg-light-gray' %>"></div>

          <!-- カードの中身 -->
          <div class="flex-1 p-4">

            <!-- 商品名 -->
            <h2 class="text-2xl font-bold text-black">
              <%= item.name %>
            </h2>

            <!-- 仕切り線 -->
            <hr class="my-2 border-t border-light-gray">

            <!--2列に分割 -->
            <div class="flex items-end justify-between">

              <!-- 左側：最安単価 -->
              <div>
                <p class="text-xs text-middle-gray">最安単価</p>
                <% if cheapest %>
                  <div class="flex items-baseline gap-1 mt-1">
                    <p class="text-2xl font-bold text-primary leading-none">
                      <%= cheapest.unit_price %>
                    </p>
                    <span class="text-sm font-normal text-black">円</span>
                    <span class="text-xs text-middle-gray">/ 1<%= cheapest.content_unit.name %></span>
                  </div>
                <% else %>
                  <p class="text-lg text-middle-gray mt-1">未登録</p>
                <% end %>
              </div>
              <!-- 右側：任意項目は存在するときだけ表示（店舗名・包装数と単位）（内容量・単位・価格は必須） -->
              <div class="text-right">

                <% if cheapest&.store.present? %>
                  <div class="inline-flex items-center gap-1 bg-light-gray/40 rounded-full px-2 py-1 mb-1">
                    <span class="material-symbols-outlined text-dark-gray" style="font-size:13px;">storefront</span>
                    <span class="text-xs text-dark-gray"><%= cheapest.store.name %></span>
                  </div>
                <% end %>

                <% if cheapest %>
                  <p class="text-xs text-middle-gray">
                    <% if cheapest.pack_unit.present? %>
                      <%= cheapest.pack_quantity %><%= cheapest.pack_unit.name %> × <%= cheapest.content_quantity %><%= cheapest.content_unit.name %>
                    <% elsif cheapest.pack_quantity > 1 %>
                      <%= cheapest.pack_quantity %> × <%= cheapest.content_quantity %><%= cheapest.content_unit.name %>
                    <% else %>
                      <%= cheapest.content_quantity %><%= cheapest.content_unit.name %>
                    <% end %>
                  </p>
                  <p class="text-sm font-bold text-black">¥<%= cheapest.price %></p>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>
      <!-- 商品登録遷移ボタン -->
      <div class="fixed bottom-28 left-0 right-0 mx-auto max-w-3xl px-6 flex justify-end z-25">
        <%= link_to new_item_registration_path, class: "card bg-accent text-white px-6 py-4 rounded-full flex items-center justify-center font-bold", data: { controller: "button", action: "touchstart->button#press touchend->button#release touchcancel->button#release" } do %>
          <span class="text-lg">商品登録</span>
          <span class="material-symbols-outlined">add</span>
        <% end %>
      </div>
    </div>
  <% end %>

<!-- itemにデータがない場合の誘導表示 -->
<% else %>
  <main class="flex flex-1 flex-col items-center justify-center px-6 py-12">
    <div class="w-full max-w-sm flex flex-col items-center text-center">
      <div class="mb-8 flex h-24 w-24 items-center justify-center rounded-full bg-secondary/10">
        <span class="material-symbols-outlined text-secondary text-5xl">add</span>
      </div>
      <div class="mb-10 space-y-3">
        <h2 class="text-2xl font-bold tracking-tight text-black">データがありません</h2>
        <p class="text-middle-gray text-sm leading-relaxed max-w-[240px] mx-auto">
          まだ登録されている商品はありません。最初のステップを始めましょう。
        </p>
      </div>
      <%= link_to new_item_registration_path, class: "flex w-full items-center justify-center gap-2 rounded-xl bg-primary py-4 px-8 text-white font-bold transition-transform active:scale-95" do %>
        <span class="material-symbols-outlined text-xl">add</span>
        <span>商品を登録する</span>
      <% end %>
    </div>
  </main>
<% end %>
